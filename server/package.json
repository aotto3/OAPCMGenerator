{
  "name": "oap-contest-manager-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:auth": "better-auth migrate --config src/auth.ts -y"
  },
  "dependencies": {
    "@better-auth/cli": "^1.2.9",
    "better-auth": "^1.2.9",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "pg": "^8.13.1",
    "resend": "^4.5.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "pg-mem": "^3.0.5",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
