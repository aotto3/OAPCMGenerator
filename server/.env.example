# OAP Contest Manager API — environment configuration.
# Copy to `.env` for local dev (server/.env is gitignored). In production these
# are set in the Railway service's Variables tab — NEVER commit real secrets.

# --- Database ---------------------------------------------------------------
# Postgres connection string. Locally, your own Postgres; in production, the
# reference Railway injects from the Postgres plugin (e.g. ${{ Postgres.DATABASE_URL }}).
DATABASE_URL=postgres://user:password@localhost:5432/oap

# --- URLs -------------------------------------------------------------------
# SINGLE-ORIGIN in production (Slice 17, #46): the frontend host reverse-proxies
# /api/* to this API, so the browser sees one origin and SERVER_URL == WEB_ORIGIN
# == that public origin (e.g. https://oapmanager.allenotto.com). Magic links and
# OAuth callbacks are built from SERVER_URL, so it must be the PUBLIC origin the
# browser uses (no trailing slash) — NOT this service's internal Railway URL.
SERVER_URL=http://localhost:8080
# Browser origin of the frontend (same as SERVER_URL in the single-origin setup).
# Used for CORS, Better Auth trustedOrigins, and the GET / → app redirect.
WEB_ORIGIN=http://localhost:5173
# Port to listen on. Railway sets PORT automatically; default 8080 locally.
PORT=8080

# --- Better Auth ------------------------------------------------------------
# Secret used to sign sessions/tokens. Generate a long random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# --- Admin panel ------------------------------------------------------------
# Comma-separated emails allowed to reach the admin API (and thus see the admin
# panel in the app). A session is admin iff its email is in this list; everyone
# else gets a 404 on every /api/admin route, so the panel stays invisible. Leave
# blank to disable the panel entirely. Case-insensitive.
ADMIN_EMAILS=

# --- Google OAuth -----------------------------------------------------------
# From the Google Cloud Console OAuth client (see README for the consent-screen
# and redirect-URI setup). Because SERVER_URL is the public single origin, the
# Authorized redirect URI must be:
#   {SERVER_URL}/api/auth/callback/google
#   e.g. https://oapmanager.allenotto.com/api/auth/callback/google
# and the Authorized JavaScript origin must be {SERVER_URL}.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- MailerSend (magic-link email) ------------------------------------------
# API token from mailersend.com. If left blank (or no From email below), the
# server logs the magic link to the console instead of emailing (handy for local
# dev — no provider needed).
MAILERSEND_API_KEY=
# The From address for sign-in emails. Must be on a domain you have verified in
# MailerSend (SPF/DKIM/Return-Path records — Wix-compatible, no MX needed).
MAGIC_LINK_FROM_EMAIL=signin@allenotto.com
MAGIC_LINK_FROM_NAME=OAP Contest Manager
