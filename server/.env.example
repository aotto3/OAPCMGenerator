# OAP Contest Manager API — environment configuration.
# Copy to `.env` for local dev (server/.env is gitignored). In production these
# are set in the Railway service's Variables tab — NEVER commit real secrets.

# --- Database ---------------------------------------------------------------
# Postgres connection string. Locally, your own Postgres; in production, the
# reference Railway injects from the Postgres plugin (e.g. ${{ Postgres.DATABASE_URL }}).
DATABASE_URL=postgres://user:password@localhost:5432/oap

# --- URLs -------------------------------------------------------------------
# Public URL of THIS API service. Magic links and OAuth callbacks are built from
# it, so it must exactly match the deployed origin (no trailing slash).
SERVER_URL=http://localhost:8080
# Browser origin of the frontend, allowed for CORS and auth. In production this
# is the static frontend's Railway URL (or your custom domain).
WEB_ORIGIN=http://localhost:5173
# Port to listen on. Railway sets PORT automatically; default 8080 locally.
PORT=8080

# --- Better Auth ------------------------------------------------------------
# Secret used to sign sessions/tokens. Generate a long random value, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# --- Google OAuth -----------------------------------------------------------
# From the Google Cloud Console OAuth client (see README for the consent-screen
# and redirect-URI setup). Authorized redirect URI must be:
#   {SERVER_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- MailerSend (magic-link email) ------------------------------------------
# API token from mailersend.com. If left blank (or no From email below), the
# server logs the magic link to the console instead of emailing (handy for local
# dev — no provider needed).
MAILERSEND_API_KEY=
# The From address for sign-in emails. Must be on a domain you have verified in
# MailerSend (SPF/DKIM/Return-Path records — Wix-compatible, no MX needed).
MAGIC_LINK_FROM_EMAIL=signin@allenotto.com
MAGIC_LINK_FROM_NAME=OAP Contest Manager
