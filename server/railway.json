{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'No compile step: the server runs TypeScript directly via tsx.'"
  },
  "deploy": {
    "startCommand": "npm run migrate:auth && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
