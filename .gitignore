# Ignore everything by default
*

# Un-ignore the files we want to track
!.gitignore

# Project documentation (root)
!CLAUDE.md
!ARCHITECTURE.md
!USER_GUIDE.md

!_Templates/
!_Templates/OAP Contest Setup.html
!output/
!output/context.md
!output/build_guide.py
!Adjudicator Packet Templates/
!Adjudicator Packet Templates/*.pdf

# 2.0 app (app/.gitignore excludes node_modules/ and dist/ within it)
!app/
!app/**
# 2.0 server (server/.gitignore excludes node_modules/, dist/, .env within it)
!server/
!server/**
!.claude/
!.claude/launch.json
