# Frontend build-time config (Vite). Copy to `.env.local` for local dev.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Origin of the API service (the Slice 13 server). Better Auth is mounted at
# /api/auth there. Local default is http://localhost:8080; in production set this
# to the deployed API URL (e.g. https://oap-api.up.railway.app or your domain).
VITE_API_URL=http://localhost:8080
